# =============================================================================
# Skophia — Sovereign AI Cybersecurity Platform
# Environment Configuration
# Copy to .env and customize for your deployment
# =============================================================================

# -----------------------------------------------------------------------------
# General Settings
# -----------------------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
DEFAULT_LANGUAGE=en

# -----------------------------------------------------------------------------
# Service Ports
# -----------------------------------------------------------------------------
VISUALIZATION_PORT=8000
BACKEND_PORT=3000
SYNAPSIX_PORT=3001
TRM_AGENT_PORT=3002
VICTORIA_METRICS_PORT=8428
OPENOBSERVE_PORT=5080
REDIS_PORT=6379
GRAFANA_PORT=3003

# -----------------------------------------------------------------------------
# OpenObserve Credentials
# IMPORTANT: Change these in production!
# -----------------------------------------------------------------------------
OPENOBSERVE_USER=admin@skophia.local
OPENOBSERVE_PASSWORD=ChangeMeInProduction!

# -----------------------------------------------------------------------------
# Grafana Credentials (optional monitoring profile)
# IMPORTANT: Change these in production!
# -----------------------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=ChangeMeInProduction!

# -----------------------------------------------------------------------------
# VictoriaMetrics Settings
# -----------------------------------------------------------------------------
VICTORIA_METRICS_RETENTION=90d

# -----------------------------------------------------------------------------
# Redis Settings
# -----------------------------------------------------------------------------
REDIS_MAXMEMORY=256mb

# -----------------------------------------------------------------------------
# Synapsix Configuration
# -----------------------------------------------------------------------------
# Minimum confidence score to emit alerts (0.0-1.0)
SYNAPSIX_ALERT_MIN_CONFIDENCE=0.4
# Enable NIS2 notification formatting
SYNAPSIX_NIS2_ENABLED=true

# -----------------------------------------------------------------------------
# TRM Agent Configuration (optional, profile: trm)
# -----------------------------------------------------------------------------
TRM_AGENT_ID=trm-demo-001
TRM_UPSTREAM_URL=http://backend:3000
TRM_CONNECTIVITY_CHECK_MS=30000
TRM_LOCAL_DETECTION=true
TRM_BUFFER_MAX_ENTRIES=100000
TRM_BUFFER_MAX_SIZE_MB=100

# -----------------------------------------------------------------------------
# Edge Mode / Air-Gap Deployment
# -----------------------------------------------------------------------------
# AIOBS_EDGE_MODE=false
# AIOBS_UPSTREAM_URL=https://skophia-central.example.com/api/sync
# AIOBS_EDGE_STORAGE_PATH=./data/edge-buffer
# AIOBS_EDGE_MAX_BUFFER_MB=100
# AIOBS_EDGE_MAX_ENTRIES=100000
# AIOBS_EDGE_TTL_HOURS=168
# AIOBS_EDGE_SYNC_STRATEGY=priority_first
# AIOBS_EDGE_CONNECTIVITY_CHECK_INTERVAL=30000
# AIOBS_EDGE_SYNC_BATCH_SIZE=500

# -----------------------------------------------------------------------------
# OT Connectors (Simulation Mode by Default)
# -----------------------------------------------------------------------------
# AIOBS_OT_SIMULATION=true
# AIOBS_OPCUA_ENDPOINT=opc.tcp://localhost:4840
# AIOBS_MODBUS_HOST=localhost
# AIOBS_MODBUS_PORT=502
# AIOBS_MQTT_BROKER=mqtt://localhost:1883

# -----------------------------------------------------------------------------
# Security (Production)
# -----------------------------------------------------------------------------
# JWT_SECRET=your-super-secret-jwt-key-change-in-production
# API_KEY=your-api-key-for-external-integrations

# -----------------------------------------------------------------------------
# AI Assistant Configuration (using LiteLLM)
# Provider: openai, anthropic, mistral, or mock (default: mock)
# -----------------------------------------------------------------------------
LLM_PROVIDER=mock
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=60
