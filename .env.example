# =============================================================================
# AIOBS Environment Configuration
# Copy to .env and customize for your deployment
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Compose Settings
# -----------------------------------------------------------------------------
# Enable bake delegation for faster parallel builds
# COMPOSE_BAKE=true

# -----------------------------------------------------------------------------
# General Settings
# -----------------------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
DEFAULT_LANGUAGE=en

# -----------------------------------------------------------------------------
# Service Ports
# -----------------------------------------------------------------------------
VISUALIZATION_PORT=8000
BACKEND_PORT=3000
VICTORIA_METRICS_PORT=8428
OPENOBSERVE_PORT=5080
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# -----------------------------------------------------------------------------
# OpenObserve Credentials
# -----------------------------------------------------------------------------
OPENOBSERVE_USER=admin@aiobs.local
OPENOBSERVE_PASSWORD=Complexpass#123

# -----------------------------------------------------------------------------
# Grafana Credentials
# -----------------------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# -----------------------------------------------------------------------------
# VictoriaMetrics Settings
# -----------------------------------------------------------------------------
VICTORIA_METRICS_RETENTION=90d

# -----------------------------------------------------------------------------
# Redis Settings
# -----------------------------------------------------------------------------
REDIS_MAXMEMORY=256mb

# -----------------------------------------------------------------------------
# Edge Mode / Air-Gap Deployment
# -----------------------------------------------------------------------------
# AIOBS_EDGE_MODE=false
# AIOBS_UPSTREAM_URL=https://aiobs-central.example.com/api/sync
# AIOBS_EDGE_STORAGE_PATH=./data/edge-buffer
# AIOBS_EDGE_MAX_BUFFER_MB=100
# AIOBS_EDGE_MAX_ENTRIES=100000
# AIOBS_EDGE_TTL_HOURS=168
# AIOBS_EDGE_SYNC_STRATEGY=priority_first
# AIOBS_EDGE_CONNECTIVITY_CHECK_INTERVAL=30000
# AIOBS_EDGE_SYNC_BATCH_SIZE=500

# -----------------------------------------------------------------------------
# OT Connectors (Simulation Mode by Default)
# -----------------------------------------------------------------------------
# AIOBS_OT_SIMULATION=true
# AIOBS_OPCUA_ENDPOINT=opc.tcp://localhost:4840
# AIOBS_MODBUS_HOST=localhost
# AIOBS_MODBUS_PORT=502
# AIOBS_MQTT_BROKER=mqtt://localhost:1883
# AIOBS_SNMP_HOST=localhost

# -----------------------------------------------------------------------------
# Security (Production)
# -----------------------------------------------------------------------------
# JWT_SECRET=your-super-secret-jwt-key-change-in-production
# API_KEY=your-api-key-for-external-integrations

# -----------------------------------------------------------------------------
# External Integrations (Optional)
# -----------------------------------------------------------------------------
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
# PAGERDUTY_API_KEY=your-pagerduty-key
# DATADOG_API_KEY=your-datadog-key

# -----------------------------------------------------------------------------
# AI/ML Provider Keys (Optional)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# MISTRAL_API_KEY=your-mistral-api-key
# HUGGINGFACE_API_KEY=hf_xxx

# -----------------------------------------------------------------------------
# AI Assistant Configuration (using LiteLLM)
# -----------------------------------------------------------------------------
# LLM Provider: openai, anthropic, mistral, or mock (default: mock)
# The chatbot uses LiteLLM for unified multi-provider support
LLM_PROVIDER=mock

# OpenAI Configuration (when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o-mini

# Anthropic Configuration (when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# Mistral Configuration (when LLM_PROVIDER=mistral)
# MISTRAL_API_KEY=your-mistral-api-key
# MISTRAL_MODEL=mistral-large-latest
# Note: LiteLLM uses "mistral/model-name" format internally

# LLM Settings
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=60

# -----------------------------------------------------------------------------
# Quick Start Examples:
# -----------------------------------------------------------------------------
# For OpenAI:
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=sk-your-key
#
# For Anthropic:
#   LLM_PROVIDER=anthropic
#   ANTHROPIC_API_KEY=sk-ant-your-key
#
# For Mistral:
#   LLM_PROVIDER=mistral
#   MISTRAL_API_KEY=your-mistral-key
